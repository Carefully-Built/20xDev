# Web3Forms — Contact form submission
# Get your access key at https://web3forms.com/
NEXT_PUBLIC_WEB3FORMS_KEY=your_access_key_here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Convex
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# WorkOS AuthKit
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_REDIRECT_URI=
WORKOS_COOKIE_PASSWORD=

# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_REVALIDATE_SECRET=

# General Translation
GT_API_KEY=
GT_PROJECT_ID=

# Featurebase — Feature request and feedback portal
# Get your org name from https://featurebase.app
NEXT_PUBLIC_FEATUREBASE_ORG=your-org-name

# Intercom — Customer support chat widget
# Get your App ID at https://app.intercom.com/a/apps/_/settings/identity-verification/web
NEXT_PUBLIC_INTERCOM_APP_ID=
